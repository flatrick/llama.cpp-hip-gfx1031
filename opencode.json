{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local-llama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "dummy"
      },
      "models": {
        "qwen-local": {
          "name": "Local Qwen 3.5 9B",
          "maxTokens": 8192
        }
      }
    }
  },
  "model": "local-llama/qwen-local",
  "permission": {
    "bash": "ask",
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "patch": "allow",
    "skill": "allow",
    "webfetch": "deny"
  }
}
